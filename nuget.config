<!-- nuget.config (repo root) — hermetic: clear inherited sources so local restores resolve
     EXACTLY what CI does (nuget.org only). Prevents a machine-local feed from shadowing a public
     package and recording a divergent content hash into packages.lock.json (CI NU1403). This repo
     depends only on public packages; the FS.GG.Audio.* packages are ProjectReferences, not deps. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
